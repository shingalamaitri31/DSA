class Solution {
  public:
    // Function to find all elements in array that appear more than n/k times.
    int countOccurence(vector<int>& arr, int k) {
        // Your code here
        unordered_map<int,int>count; int n=arr.size();
        for(int i=0;i<n;i++){
            count[arr[i]]++;
        } int ans=0;
        for(int i=0;i<n;i++){
            if(count[arr[i]]>(n/k)){ 
                    ans++; count[arr[i]]=0;
            } }
            return ans;
        
    }
};
