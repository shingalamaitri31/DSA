class Solution {
public:
    int eggDrop(int n, int k) {

        vector<long long> dp(n + 1, 0);

        int moves = 0;

        while (dp[n] < k) {
            moves++;

            for (int e = n; e >= 1; e--) {
                dp[e] = dp[e] + dp[e - 1] + 1;
            }
        }

        return moves;
    }
};
