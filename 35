class Solution {
  public:
    vector<pair<int, int>> findPairsWithGivenSum(Node *head, int target) {
          vector<pair<int, int>>ans;
          Node* c=head; int count=0;
          while(c->next!=NULL){
              count++;c=c->next;  }
              int s=0; int e=count;
             
              while(s<e){ int sd=head->data;int ed=c->data;
                  if(sd+ed>target){e--;c=c->prev;}
                  else if(sd+ed<target){s++;head=head->next;}
                  else{
                      ans.push_back({sd,ed});s++;e--;
                      c=c->prev; head=head->next;
                  }
              } return ans;
    }
};
