class Solution {
  public:
    int minFlips(string& s) {
      int cnt1=0;int cnt2=0;
      for(int i=0;i<s.size();i++){
          char c1=(i%2==0)?'0':'1';
          char c2=(i%2==0)?'1':'0';
          if(s[i]!=c1){cnt1++;}
          if(s[i]!=c2){cnt2++;}
      }
        return min(cnt1,cnt2);
    }
};
