class Solution {
  public:
    // Function to check if b is a subset of a
    bool isSubset(vector<int> &a, vector<int> &b) {
        unordered_map<int,int>store;
        
        for(int i=0;i<a.size();i++){
            store[a[i]]++; }
            for(int i=0;i<b.size();i++){
                store[b[i]]--;
                if(store[b[i]]==-1){return false;}
            } return true;}};
