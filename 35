class Solution {
public:
    
    void inorder(vector<int>& arr, int idx, vector<int>& in) {
        if(idx >= arr.size()) return;

        inorder(arr, 2 * idx + 1, in);
        in.push_back(arr[idx]);
        inorder(arr, 2 * idx + 2, in);
    }

    int minSwaps(vector<int>& arr) {
        vector<int> in;
        inorder(arr, 0, in);

        int n = in.size();

        vector<pair<int,int>> vp;
        for(int i = 0; i < n; i++) {
            vp.push_back({in[i], i});
        }

        sort(vp.begin(), vp.end());

        vector<bool> vis(n, false);
        int swaps = 0;

        for(int i = 0; i < n; i++) {

            if(vis[i] || vp[i].second == i)
                continue;

            int cycleSize = 0;
            int j = i;

            while(!vis[j]) {
                vis[j] = true;
                j = vp[j].second;
                cycleSize++;
            }

            swaps += (cycleSize - 1);
        }

        return swaps;
    }
};
