#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;

    while (t--) {

        int n;
        cin >> n;

        vector<long long> a(n);

        for (int i = 0; i < n; i++) {
            cin >> a[i];
        }

        long long pref = 0;

        set<long long> seen;

        seen.insert(0);   // empty prefix

        bool found = false;

        for (int i = 0; i < n; i++) {

            // odd position (1-based)
            if ((i + 1) % 2 == 1)
                pref += a[i];

            // even position (1-based)
            else
                pref -= a[i];

            if (seen.count(pref)) {
                found = true;
                break;
            }

            seen.insert(pref);
        }

        cout << (found ? "YES" : "NO") << "\n";
    }
}
