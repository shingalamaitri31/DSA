class Solution {
  public:
    int countSetBits(int n) {

        vector<int> arr(32,0);
        arr[0]=1;
        arr[1]=4;

        for(int i=2;i<32;i++){
            arr[i] = 2*arr[i-1] + (1<<i);    }

        int ans = 0;

        while(n > 0){

            int x = 0;

            while((1<<(x+1)) <= n)
                x++;

            if(x > 0)
                ans += arr[x-1];

            ans += n - (1<<x) + 1;

            n -= (1<<x);
        }

        return ans;
    }
};
