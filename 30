#include <bits/stdc++.h>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        int n;
        cin >> n;

        vector<vector<int>> sets(n);
        set<int> total;

        for (int i = 0; i < n; i++) {
            int k;
            cin >> k;

            sets[i].resize(k);

            for (int j = 0; j < k; j++) {
                cin >> sets[i][j];
                total.insert(sets[i][j]);
            }
        }

        int ans = 0;

        for (int x : total) {

            set<int> cur;

            for (int i = 0; i < n; i++) {

                bool present = false;

                for (int y : sets[i]) {
                    if (y == x) {
                        present = true;
                        break;
                    }
                }

                if (!present) {
                    for (int y : sets[i])
                        cur.insert(y);
                }
            }

            ans = max(ans, (int)cur.size());
        }

        cout << ans << '\n';
    }
}